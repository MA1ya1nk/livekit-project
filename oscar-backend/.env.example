# Copy to .env and fill in values

# Database (async for FastAPI)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name
ALEMBIC_DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
FRONTEND_RESET_PASSWORD_URL=
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=

# Twilio (voice webhooks + number config)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
VOICE_WEBHOOK_BASE_URL=https://your-api.com

# OpenAI (voice agent)
OPENAI_API_KEY=

# Redis (voice call state; optional — in-memory used if not set)
REDIS_URL=

# Optional
DEBUG=False

# Super admin user
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=